<% layout('/layout/boilerplate') -%>

    <div class="container py-5">
        <%- include('../partials/flash') %>

            <% if (cart.length===0) { %>
                <div class="alert alert-info text-center py-5">
                    <h4>Your cart is empty!</h4>
                    <p>Start shopping to add items to your cart</p>
                    <a href="/products" class="btn btn-primary mt-3">Continue Shopping</a>
                </div>
                <% } else { %>
                    <div class="row">
                        <div class="col-lg-8">
                            <h2 class="mb-4">Shopping Cart (<%= cart.length %> items)</h2>

                            <% for( let item of cart ) { %>
                                <% if (item.productId) { %>
                                    <div class="card mb-3">
                                        <!-- ... card content ... -->
                                        <div class="row g-0">
                                            <div class="col-md-3">
                                                <img src="<%= item.productId.image %>" class="img-fluid rounded-start"
                                                    alt="<%= item.productId.name %>"
                                                    style="height: 150px; object-fit: cover;">
                                            </div>
                                            <div class="col-md-6">
                                                <div class="card-body">
                                                    <h5 class="card-title">
                                                        <%= item.productId.name %>
                                                    </h5>
                                                    <p class="card-text text-muted">
                                                        <%= item.productId.desc %>
                                                    </p>
                                                    <h6 class="card-text">Price: <span class="text-primary fw-bold">₹
                                                            <%= item.productId.price %></span></h6>
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="card-body d-flex flex-column justify-content-between h-100">
                                                    <div
                                                        class="d-flex align-items-center justify-content-center gap-2 mb-3">
                                                        <form action="/user/<%= item.productId._id %>/cart/decrease"
                                                            method="post" class="d-inline">
                                                            <button type="submit"
                                                                class="btn btn-outline-secondary btn-sm">−</button>
                                                        </form>
                                                        <span class="fw-bold"
                                                            style="min-width: 30px; text-align: center;">
                                                            <%= item.quantity %>
                                                        </span>
                                                        <form action="/user/<%= item.productId._id %>/cart/add"
                                                            method="post" class="d-inline">
                                                            <button type="submit"
                                                                class="btn btn-outline-secondary btn-sm">+</button>
                                                        </form>
                                                    </div>
                                                    <form action="/user/<%= item.productId._id %>/cart/remove"
                                                        method="post" class="w-100">
                                                        <button type="submit"
                                                            class="btn btn-danger btn-sm w-100">Remove</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <% } %>
                                        <% } %>
                        </div>

                        <div class="col-lg-4">
                            <div class="card sticky-top" style="top: 100px;">
                                <div class="card-body">
                                    <h5 class="card-title">Order Summary</h5>
                                    <hr>

                                    <div class="mb-3">
                                        <% let subtotal=0; %>
                                            <% for( let item of cart ) { %>
                                                <% subtotal +=item.productId.price * item.quantity; %>
                                                    <div class="d-flex justify-content-between mb-2">
                                                        <span>
                                                            <%= item.productId.name %> <span class="text-muted">x <%=
                                                                        item.quantity %></span>
                                                        </span>
                                                        <span>₹ <%= (item.productId.price * item.quantity).toFixed(2) %>
                                                        </span>
                                                    </div>
                                                    <% } %>
                                    </div>

                                    <hr>

                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Subtotal</span>
                                        <span id="subtotal">₹ <%= subtotal.toFixed(2) %></span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-3">
                                        <span>Tax (10%)</span>
                                        <span id="tax">₹ <%= (subtotal * 0.1).toFixed(2) %></span>
                                    </div>

                                    <hr>

                                    <div class="d-flex justify-content-between fw-bold text-primary">
                                        <span>Total</span>
                                        <span id="total-amount">₹ <%= (subtotal * 1.1).toFixed(2) %></span>
                                    </div>

                                    <a href="/checkout" class="btn btn-primary w-100 mt-4">Proceed to Checkout</a>
                                    <a href="/products" class="btn btn-outline-primary w-100 mt-2">Continue Shopping</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>
    </div>