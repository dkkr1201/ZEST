<% layout('/layout/boilerplate') -%>

    <%- include('../partials/flash') %>

        <div class="container py-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold">My Dashboard</h2>
                <a href="/products/new" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Add New Product
                </a>
            </div>

            <% if(products.length===0) { %>
                <div class="text-center py-5 shadow-sm rounded bg-light mt-4">
                    <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                    <h3>No products found</h3>
                    <p class="text-muted">You haven't listed any products yet. Start selling today!</p>
                    <a href="/products/new" class="btn btn-primary mt-2">Create Your First Product</a>
                </div>
                <% } else { %>
                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                        <% for( let product of products ) { %>
                            <div class="col">
                                <div class="card h-100 shadow-sm border-0 product-card">
                                    <img src="<%= product.image %>" class="card-img-top"
                                        style="height: 200px; object-fit: cover;" alt="<%= product.name %>">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h5 class="card-title fw-bold mb-0 text-truncate" style="max-width: 70%;">
                                                <%= product.name %>
                                            </h5>
                                            <span class="badge bg-primary">₹ <%= product.price %></span>
                                        </div>
                                        <p class="card-text text-muted small mb-3 text-truncate-2">
                                            <%= product.desc %>
                                        </p>

                                        <div class="d-flex gap-2 mt-auto">
                                            <a href="/products/<%= product._id %>"
                                                class="btn btn-outline-primary btn-sm flex-grow-1">
                                                <i class="fas fa-eye"></i> View
                                            </a>
                                            <a href="/products/<%= product._id %>/edit"
                                                class="btn btn-outline-success btn-sm flex-grow-1">
                                                <i class="fas fa-edit"></i> Edit
                                            </a>
                                            <form action="/products/<%= product._id %>?_method=DELETE" method="POST"
                                                class="d-inline flex-grow-1"
                                                onsubmit="return confirm('Delete this product?');">
                                                <button class="btn btn-outline-danger btn-sm w-100">
                                                    <i class="fas fa-trash"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                    <div class="card-footer bg-transparent border-0 pt-0 pb-3">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <small class="text-muted">
                                                <i class="fas fa-star text-warning me-1"></i>
                                                <%= product.avgRating %> (<%= product.reviews.length %> reviews)
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% } %>
                    </div>
                    <% } %>
        </div>

        <style>
            .product-card {
                transition: transform 0.2s ease, box-shadow 0.2s ease;
            }

            .product-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1) !important;
            }

            .text-truncate-2 {
                display: -webkit-box;
                -webkit-line-clamp: 2;
                line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }
        </style>